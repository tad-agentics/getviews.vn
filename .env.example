# Environment Variables — GetViews.vn
# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it is gitignored.

# ─── Supabase (required) ───────────────────────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=              # Server-only — Edge Functions only, never in frontend

# ─── Resend (Monday emails, trend alerts) ──────────────────────────────
RESEND_API_KEY=                         # Server-only — Edge Functions only

# ─── PayOS (Vietnamese payments: MoMo, VNPay, bank transfer, card) ─────
PAYOS_CLIENT_ID=                        # Server-only — Edge Functions only
PAYOS_API_KEY=                          # Server-only — Edge Functions only
PAYOS_CHECKSUM_KEY=                     # Server-only — Edge Functions only

# ─── Gemini (video analysis + synthesis) ───────────────────────────────
GEMINI_API_KEY=                         # Server-only — Cloud Run + Edge Functions only
# Models: gemini-3.1-flash-lite-preview (extraction) / gemini-3-flash-preview (synthesis)

# ─── EnsembleData (TikTok metadata + CDN video URLs) ───────────────────
ENSEMBLEDATA_API_KEY=                   # Server-only — Cloud Run only

# ─── Cloudflare R2 (frame storage) ─────────────────────────────────────
R2_ACCOUNT_ID=                          # Server-only — Cloud Run only
R2_ACCESS_KEY_ID=                       # Server-only — Cloud Run only
R2_SECRET_ACCESS_KEY=                   # Server-only — Cloud Run only
R2_BUCKET_NAME=getviews-frames          # Server-only — Cloud Run only
VITE_R2_PUBLIC_URL=                     # Client-safe — public CDN URL for frame thumbnails

# ─── Cloud Run (video analysis service) ────────────────────────────────
VITE_CLOUD_RUN_URL=                     # Client-safe — SSE endpoint for video intents
CLOUD_RUN_JWT_SECRET=                   # Server-only — shared with Cloud Run for JWT validation

# ─── Residential proxy (TikTok CDN bypass) ─────────────────────────────
PROXY_URL=                              # Server-only — Cloud Run only (e.g. Webshare/IPRoyal)

# ─── LLM via OpenRouter (optional — for non-Gemini LLM calls) ──────────
# OPENROUTER_API_KEY=                   # Server-only — Edge Functions only
