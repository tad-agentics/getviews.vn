# Environment Variables — GetViews.vn
# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it is gitignored.

# ─── Supabase (required) ───────────────────────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=              # Server-only — Edge Functions only, never in frontend
SUPABASE_JWT_SECRET=                    # Server-only — Cloud Run JWT validation (stateless auth)

# ─── Gemini (Google Cloud) ─────────────────────────────────────────────
GEMINI_API_KEY=                         # Server-only — Cloud Run + Edge Functions
# Default models (per §11 prompt architecture):
#   Batch/extraction: gemini-3.1-flash-lite-preview  ($0.25/$1.50 per 1M tokens)
#   Synthesis: gemini-3-flash-preview                ($0.50/$3.00 per 1M tokens)

# ─── EnsembleData (TikTok metadata API) ───────────────────────────────
ENSEMBLEDATA_API_KEY=                   # Server-only — Cloud Run + Edge Functions
# Plan: Wood ($100/mo, 1,500 units/day) — separate project from GetReels global

# ─── Residential proxy ────────────────────────────────────────────────
PROXY_URL=                              # Server-only — Cloud Run (format: http://user:pass@host:port)
# Evaluate Webshare + IPRoyal during Foundation week. Criteria: VN CDN success rate, $/GB, API.

# ─── PayOS (Vietnamese payment aggregator) ────────────────────────────
PAYOS_CLIENT_ID=                        # Server-only — Edge Functions
PAYOS_API_KEY=                          # Server-only — Edge Functions
PAYOS_CHECKSUM_KEY=                     # Server-only — webhook signature verification
# Webhook events to handle: payment.paid, payment.cancelled, payment.expired
# Requires Vietnamese business license (hộ kinh doanh cá thể or công ty TNHH)

# ─── Resend (transactional email) ─────────────────────────────────────
RESEND_API_KEY=                         # Server-only — Edge Functions
# Used for: Monday plan emails, trend digests, expiry reminders (7d/3d/1d before)

# ─── Cloudflare R2 (frame storage) ────────────────────────────────────
R2_ACCOUNT_ID=                          # Server-only — Cloud Run batch job
R2_ACCESS_KEY_ID=                       # Server-only
R2_SECRET_ACCESS_KEY=                   # Server-only
R2_BUCKET_NAME=getviews-frames
# Public bucket URL: https://frames.getviews.vn/{video_id}/{frame_n}.webp

# ─── Cloud Run ────────────────────────────────────────────────────────
CLOUD_RUN_API_URL=                      # Client-safe — SSE endpoint for video intents
# Example: https://getviews-api-xxxxx.run.app
VITE_CLOUD_RUN_API_URL=                 # VITE_ prefix for client bundle (same value as above)

# ─── Optional: Zalo webhook alerts ────────────────────────────────────
# ZALO_WEBHOOK_URL=                     # Server-only — critical alert notifications
