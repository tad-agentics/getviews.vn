# ── EnsembleData (TikTok data source) ─────────────────────────────────────────
# Must match tech-spec §12: ENSEMBLE_DATA_API_KEY
ENSEMBLE_DATA_API_KEY=
# Keyword search: set true only if play_count is missing without author stats (may cost more units).
KEYWORD_SEARCH_AUTHOR_STATS=false
# Carousel pool: second hashtag pass (legacy, 2× hashtag ED cost per niche). Default false.
CORPUS_LEGACY_CAROUSEL_HASHTAG_FETCH=false
# Per-endpoint unit weights for [ed-meter] est_units (see artifacts/docs/ed-pricing-map.md)
# ED_UNIT_KEYWORD_SEARCH=1
# ED_UNIT_HASHTAG_POSTS=1
# ED_UNIT_POST_INFO=1
# ED_UNIT_POST_MULTI_INFO=1
# ED_UNIT_USER_POSTS=1
# ED_UNIT_USER_SEARCH=1
# ED_UNIT_POST_COMMENTS=1
# Optional: cap batch-class ED HTTP requests per UTC day (0 = off). Prefer log-only first.
# ED_BATCH_DAILY_REQUEST_MAX=0
# ED_BATCH_BUDGET_ENFORCE=false
# Tier-3 /classify-intent Gemini calls per UTC day (0 = unlimited). When exceeded, deterministic fallback.
# CLASSIFIER_GEMINI_DAILY_MAX=0
# User-path TTL cache (post/info, user/posts) — seconds / max entries
# ENSEMBLE_USER_PATH_CACHE_TTL_SEC=300
# ENSEMBLE_USER_PATH_CACHE_MAX=2000
# Reingest multi-info chunk size (URL limits + billing tradeoff)
# REINGEST_MULTI_CHUNK=12

# ── TikHub (Douyin data source — Kho Douyin pipeline) ─────────────────────────
# Provider for the Douyin batch ingest. EnsembleData's /douyin/* mirror
# returns empty payloads in production; TikHub proxies the Douyin web
# internal API directly. See cloud-run/getviews_pipeline/tikhub_douyin.py.
TIKHUB_API_KEY=
# Override only if TikHub publishes a regional endpoint; otherwise leave default.
# TIKHUB_BASE_URL=https://api.tikhub.io
# Per-call HTTP timeout (seconds). TikHub fans Douyin internal-API
# requests through their backend so an upstream stall can chain.
# TIKHUB_REQUEST_TIMEOUT_SEC=20.0
# Cap on TikHub Douyin HTTP calls per UTC day (0 = unlimited). Mirrors
# ED_BATCH_DAILY_REQUEST_MAX. Bump after the first week of clean cron runs.
TIKHUB_DOUYIN_DAILY_REQUEST_MAX=50

# ── Google Gemini ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=
# Video understanding model (full multimodal)
GEMINI_MODEL=gemini-3-flash-preview
# Fast text-only synthesis model for Vietnamese output
GEMINI_SYNTHESIS_MODEL=gemini-3.1-flash-lite-preview
# Batch indexing / knowledge Q&A model
GEMINI_BATCH_MODEL=gemini-3.1-flash-lite-preview
# Optional: low | medium | high — resolution for video uploads
# GEMINI_VIDEO_MEDIA_RESOLUTION=medium

# ── Supabase (session storage + video_corpus lookup) ──────────────────────────
SUPABASE_URL=
# Anon/publishable key — same value as VITE_SUPABASE_PUBLISHABLE_KEY in the frontend.
# Used by user_supabase() to run RLS-scoped queries (credit deduction, chat_messages).
SUPABASE_ANON_KEY=
# Service role key — only needed for admin operations (not used in /stream handler).
SUPABASE_SERVICE_ROLE_KEY=

# ── Supabase JWT validation (ES256 / JWKS — no shared secret needed) ──────────
# Cloud Run validates incoming JWTs via JWKS — stateless, asymmetric, key-rotatable.
# Do NOT use SUPABASE_JWT_SECRET (HS256 legacy) unless absolutely required.
#
# Resolution order in config.py:
#   1. SUPABASE_JWKS_URL (explicit) — set this for staging/local-dev only.
#   2. ${SUPABASE_URL}/auth/v1/.well-known/jwks.json — derived automatically
#      so the project ref isn't pinned in the source tree.
# Leave SUPABASE_JWKS_URL blank in production; the derived URL tracks
# whichever Supabase project SUPABASE_URL points at.
SUPABASE_JWKS_URL=
SUPABASE_JWT_SECRET=  # HS256 shared secret — from Supabase Dashboard → Settings → API → JWT Secret. When set, preferred over JWKS (no network call).

# ── Cloudflare R2 (frame storage) ─────────────────────────────────────────────
# Frames are extracted at 0s, 1s, 3s and uploaded as PNGs to R2.
# frame_urls in video_corpus stores the resulting public CDN URLs.
#
# Setup:
#   1. Create an R2 bucket in Cloudflare Dashboard (e.g. "getviews-frames")
#   2. Create an R2 API token with "Object Read & Write" on that bucket
#   3. (Optional) Add a custom domain to the bucket for R2_PUBLIC_URL
#      e.g. frames.getviews.vn → Public access on the bucket
#
# Key pattern: frames/{video_id}/{0,1,2}.png
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=getviews-frames
R2_PUBLIC_URL=https://pub-5c1a9ee9dab74b06b9e122230aa9c0c5.r2.dev
# Local ffmpeg still (hook PNG + scene JPG). Default 120s; raise only if vCPU is very fast.
# FFMPEG_FRAME_TIMEOUT_SEC=120
# Second-attempt width when 720p times out or fails (faster scale/encode).
# FFMPEG_FRAME_FALLBACK_SCALE_WIDTH=480

# ── Residential Proxy (TikTok CDN downloads) ─────────────────────────────────
# TikTok blocks datacenter IPs. Set this to route video/image downloads
# through a residential proxy. EnsembleData API calls are NOT proxied.
# Format: http://user:pass@host:port
# Recommended providers: Smartproxy, Bright Data, Oxylabs
RESIDENTIAL_PROXY_URL=

# ── Corpus ingest quality gates ───────────────────────────────────────────────
# Minimum views a post must have to enter the corpus (default: 10000)
BATCH_MIN_VIEWS=10000
# Minimum engagement rate % = (likes+comments+shares)/views*100 (default: 0.5)
BATCH_MIN_ER=0.5
# How many pages of keyword search results to fetch per niche (default: 2, ~40 posts)
BATCH_KEYWORD_PAGES=2
# Videos accepted per niche per batch run (default: 30). Thin niches scale up to THIN_NICHE_MAX_MULTIPLIER×.
# BATCH_VIDEOS_PER_NICHE=30
# Star niches: floor + cap so key verticals (e.g. Thời trang) keep ingesting after thin-niche math hits 1×.
# Comma-separated niche_taxonomy.id. Set BATCH_PRIORITY_NICHE_IDS= to disable. Default includes 3 (Thời trang / Outfit).
# BATCH_PRIORITY_NICHE_IDS=3
# BATCH_PRIORITY_NICHE_VPN_FLOOR=35
# BATCH_PRIORITY_NICHE_MAX_VPN=90
# Cap batch-class EnsembleData *HTTP* requests per UTC day (0 = off). Not the same as ED “units” in the vendor dashboard;
# raise together when your daily unit budget increases (e.g. after buying more credit).
# ED_BATCH_DAILY_REQUEST_MAX=0
# ED_BATCH_BUDGET_ENFORCE=false

# Hashtag API calls per niche per run (default 15). Set 31+ to cover a long ``signal_hashtags`` list (raises ED cost for *all* niches).
# BATCH_HASHTAG_FETCH_LIMIT=15
# Per-niche cap — e.g. only Thời trang (id 3) uses 31 fetches; others keep BATCH_HASHTAG_FETCH_LIMIT.
# BATCH_HASHTAG_FETCH_BY_NICHE=3:31

# ── Service ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
PORT=8080
