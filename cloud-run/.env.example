# ── EnsembleData (TikTok data source) ─────────────────────────────────────────
ENSEMBLEDATA_API_TOKEN=

# ── Google Gemini ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=
# Video understanding model (full multimodal)
GEMINI_MODEL=gemini-3-flash-preview
# Fast text-only synthesis model for Vietnamese output
GEMINI_SYNTHESIS_MODEL=gemini-3.1-flash-lite-preview
# Batch indexing / knowledge Q&A model
GEMINI_BATCH_MODEL=gemini-3.1-flash-lite-preview
# Optional: low | medium | high — resolution for video uploads
# GEMINI_VIDEO_MEDIA_RESOLUTION=medium

# ── Supabase (session storage + video_corpus lookup) ──────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Cloudflare R2 (video clip storage) ────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=getviews-videos
R2_PUBLIC_URL=

# ── Service ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
PORT=8080
