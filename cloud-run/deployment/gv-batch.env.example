# Bước 4 — getviews-pipeline-batch
# 1) cp cloud-run/deployment/gv-batch.env.example cloud-run/deployment/gv-batch.env
# 2) Thay REPLACE_ME theo bảng nguồn bên dưới (không commit gv-batch.env)
# 3) gcloud run services update getviews-pipeline-batch --region=asia-southeast1 \
#      --project=YOUR_PROJECT --env-vars-file=cloud-run/deployment/gv-batch.env
#
# Nguồn giá trị (bạn tự mở dashboard, copy vào file cục bộ):
#   GEMINI_API_KEY     → aistudio.google.com / Google AI Studio → Get API key
#   ENSEMBLE_DATA_API_KEY → tài khoản EnsembleData (cùng key bạn dùng cho app)
#   SUPABASE_URL        → Supabase → Project → Settings → API → Project URL
#   SUPABASE_ANON_KEY   → cùng mục → anon / public (publishable)
#   SUPABASE_JWT_SECRET → cùng mục → JWT Secret (chỉ server, không lộ lên Vercel client)
#   SUPABASE_SERVICE_ROLE_KEY → cùng mục → service_role (chỉ batch, không bao giờ frontend)
#   BATCH_SECRET        → tự tạo:  openssl rand -hex 32   (dùng chung cho user service + cron)
#   R2_*  + R2_PUBLIC_URL → Cloudflare R2 → bucket + API token + public URL
#   RESIDENTIAL_PROXY_URL → Webshare / IPRoyal… (cùng URL bạn từng cấp cho batch trước khi bị mất config)
# Gợi ý: nếu trên laptop có file .env.local cũ, mở trong editor và chép từng tên trùng (VITE_ không dùng cho server).
#
SERVICE_ROLE=batch
GEMINI_API_KEY=REPLACE_ME
ENSEMBLE_DATA_API_KEY=REPLACE_ME
SUPABASE_URL=REPLACE_ME
SUPABASE_ANON_KEY=REPLACE_ME
SUPABASE_JWT_SECRET=REPLACE_ME
SUPABASE_SERVICE_ROLE_KEY=REPLACE_ME
BATCH_SECRET=REPLACE_ME
R2_ACCOUNT_ID=REPLACE_ME
R2_ACCESS_KEY_ID=REPLACE_ME
R2_SECRET_ACCESS_KEY=REPLACE_ME
R2_BUCKET_NAME=getviews-frames
R2_PUBLIC_URL=REPLACE_ME
# R2_VIDEO_PUBLIC_URL=
RESIDENTIAL_PROXY_URL=REPLACE_ME
LOG_LEVEL=INFO
