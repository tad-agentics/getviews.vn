{
  "compilerOptions": {
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "types": ["node", "vite/client", "vite-plugin-pwa/react"],
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "rootDirs": [".", "./.react-router/types"],
    "paths": {
      "~/*": ["./app/*"],
      "@/*": ["./src/*"],
      "shared": ["./shared/index.ts"],
      "shared/*": ["./shared/*"]
    },
    "esModuleInterop": true,
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "./node_modules/.cache/ts-app",
    "tsBuildInfoFile": "./node_modules/.cache/ts-app.tsbuildinfo"
  },
  "include": [
    "src",
    "shared/types/**/*.ts",
    "shared/api/ritual.ts",
    "api",
    "scripts/**/*.ts",
    ".react-router/types/**/*"
  ],
  "exclude": [
    "node_modules",
    "build",
    "dist",
    "coverage",
    "mobile",
    "artifacts",
    "supabase/functions",
    "app",
    "cloud-run",
    "src/make-import"
  ]
}
