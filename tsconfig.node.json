{
  "compilerOptions": {
    "lib": ["ES2022"],
    "types": ["node"],
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "./node_modules/.cache/ts-node",
    "tsBuildInfoFile": "./node_modules/.cache/ts-node.tsbuildinfo"
  },
  "include": [
    "vite.config.ts",
    "vitest.config.mts",
    "playwright.config.ts",
    "react-router.config.ts"
  ],
  "exclude": ["node_modules"]
}
